# Copy this file to .env.local and fill in the values.
# .env.local is gitignored; this example is committed so others know what to set.
# Set these same four variables in your hosting provider's environment settings.

# Shared access password for the Basic Auth gate (middleware.ts).
# Any username works at the login prompt; only the password is checked.
APP_PASSWORD=

# Claude API key — https://console.claude.com. Server-only; never prefix NEXT_PUBLIC_.
ANTHROPIC_API_KEY=

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=

# Supabase SERVICE ROLE key (Settings → API → service_role). Server-only, full
# DB access — never expose to the browser and never prefix NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
